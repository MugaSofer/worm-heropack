;This is "fiskheroes:swing_roll" but edited a little
{x} = curve {data}
{data} = sin(pi(1 - {data}))^2

{head_rotX} @ {data} -> 0.7
{rightArm_rotX} @ {data} -> -1.0
{rightArm_rotY} @ {data} -'> 1.5
{leftArm_rotX} @ {data} -> -1.0
{leftArm_rotY} @ {data} -'> -1.5

{rightLeg_rotX} @ {data} -> -0.6
{leftLeg_rotX} @ {data} -> 1

out "pivot" (0, 0.5, 0)
out "translate" (0, 1{data}, 0)
out "rotate" (-360{x}, 1, 0, 0)
