{data} = curve {data}

{body_rotX} @ {data} -> 0.15

{aimX} = {head_rotX} - 90'

{rightArm_rotX} @ {data} -> {aimX}
{rightArm_rotY} @ {data} -> -0.3
{rightArm_rotZ} @ {data} -> 0.15

{leftArm_rotX} @ {data} -> {aimX}
{leftArm_rotY} @ {data} -> 0.3
{leftArm_rotZ} @ {data} -> -0.15

{rightLeg_posZ} @ {data} -> -0.5
{rightLeg_rotX} @ {data} -> 0.15

{leftLeg_posZ} @ {data} -> 0.5
{leftLeg_rotX} @ {data} -> -0.1
