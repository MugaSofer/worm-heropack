{data} = curve {data}

{body_rotX} @ {data} -> 0.6
{head_rotX} @ {data} -> 0.4

{rightArm_rotX} @ {data} -> 0.8
{rightArm_rotY} @ {data} -> -0.2
{rightArm_rotZ} @ {data} -> 0.1

{leftArm_rotX} @ {data} -> 0.8
{leftArm_rotY} @ {data} -> 0.2
{leftArm_rotZ} @ {data} -> -0.1

{rightLeg_posZ} @ {data} -> 2.0
{rightLeg_rotX} @ {data} -> -0.4

{leftLeg_posZ} @ {data} -> -1.5
{leftLeg_rotX} @ {data} -> 0.3

out "firstPerson" (true)
out "translate" (0{data}, -0.5{data}, 0{data})