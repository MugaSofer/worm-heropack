{data} = curve {data}

{body_rotX} @ {data} -> 0.3
{head_rotX} @ {data} -> 0.25

{rightArm_rotX} @ {data} -> 0.8
{rightArm_rotY} @ {data} -> -0.2
{rightArm_rotZ} @ {data} -> 0.1

{leftArm_rotX} @ {data} -> 0.8
{leftArm_rotY} @ {data} -> 0.2
{leftArm_rotZ} @ {data} -> -0.1

{rightLeg_posZ} @ {data} -> 1.0
{rightLeg_rotX} @ {data} -> -0.2

{leftLeg_posZ} @ {data} -> -0.8
{leftLeg_rotX} @ {data} -> 0.15

out "firstPerson" (true)
out "translate" (0{data}, -0.25{data}, 0{data})